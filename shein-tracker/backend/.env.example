# Database
DATABASE_URL="postgresql://user:password@localhost:5432/shein_tracker"

# JWT
JWT_SECRET="your-secret-key-here"

# Admin bootstrap credentials (created automatically on first run)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="password"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Encryption
ENCRYPTION_KEY="your-32-character-encryption-key"

# Server
PORT=5000
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:3000"

# Optional Playwright proxy for scraping reliability
# Example: http://user:pass@proxy-host:port or socks5://proxy-host:port
PLAYWRIGHT_PROXY_SERVER=""
PLAYWRIGHT_PROXY_USERNAME=""
PLAYWRIGHT_PROXY_PASSWORD=""
PLAYWRIGHT_PROXY_BYPASS=""
